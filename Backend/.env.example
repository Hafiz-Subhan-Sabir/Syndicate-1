# Copy to .env in this folder (Backend/). Django loads it automatically.

# Optional production secret (dev default exists in settings.py)
# DJANGO_SECRET_KEY=

# Default password for seed_portal / demo users (demo, viewer1, admin1)
PORTAL_DEV_PASSWORD=SyndicateDev2026!

# When true, seed_portal resets passwords for demo, viewer1, admin1 every run
# PORTAL_ALWAYS_RESET_PASSWORDS=1

# Comma-separated extra CORS origins (LAN IP, another port, etc.)
# CORS_EXTRA_ORIGINS=http://192.168.1.5:3000,http://localhost:3001

# Comma-separated ALLOWED_HOSTS additions
# DJANGO_ALLOWED_HOSTS=192.168.1.5,testserver

# OpenAI (optional)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
